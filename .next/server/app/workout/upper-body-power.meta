{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/workout/layout,_N_T_/workout/[slug]/layout,_N_T_/workout/[slug]/page,_N_T_/workout/upper-body-power"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/workout/$d$slug/__PAGE__",
    "/workout/$d$slug",
    "/workout",
    "/_index",
    "/_head"
  ]
}